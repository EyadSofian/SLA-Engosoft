# ─────────────────────────────────────────────────────────────
# Supabase (client-side — MUST be the PUBLISHABLE / anon key)
# Never put the secret (service_role) key here: this value ships
# to the browser inside the built JS bundle.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://jrenyjmbbizborhbwptz.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Currency for every money figure. The database stores bare numbers with no
# currency column, so this is the single place that decides the unit.
# Defaults to USD — set these only to override.
# Supported: USD ($) · EUR (€) · GBP (£) · EGP (ج.م) · SAR (ر.س) · AED (د.إ) · KWD (د.ك)
# Keep both in step: VITE_CURRENCY drives the UI, CURRENCY the digest + AI chat.
VITE_CURRENCY=USD
CURRENCY=USD

# ─────────────────────────────────────────────────────────────
# AI chat proxy (server-side only — never prefixed with VITE_)
# Used by server/index.js and api/chat.ts
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# Port for the production server (Railway injects this automatically)
PORT=3000

# ─────────────────────────────────────────────────────────────
# Telegram daily digest (only for scripts/telegram-digest.js)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
SUPABASE_URL=https://jrenyjmbbizborhbwptz.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Management tab  (/management  +  /api/management/*)
# Server-side only. See docs/management-ai.md for the full setup.
# ─────────────────────────────────────────────────────────────

# Supabase SECRET key. This is the only place in the project that writes, so
# it needs the secret (service_role) key — never the publishable one, and
# never a VITE_ prefix.
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Temporary passcode for the tab. Without it the tab shows a "not enabled"
# message and every /api/management route returns 503.
MANAGEMENT_PASSCODE=change-me

# Optional. Signs session tokens; defaults to the passcode itself. Set it to a
# long random string so changing the passcode doesn't invalidate nothing else.
MANAGEMENT_SESSION_SECRET=
MANAGEMENT_SESSION_HOURS=12

# Shared secret the Botpress / n8n / Telegram webhooks must send as
# x-engosoft-secret (Telegram sends x-telegram-bot-api-secret-token instead —
# both headers are accepted).
MANAGEMENT_WEBHOOK_SECRET=change-me-too

# First-contact activation code. A new chat has to send this once before it can
# file anything; the server stores the chat id it already sees on the request,
# so nobody ever looks one up. Unset = no chat-level gate.
MANAGEMENT_JOIN_CODE=

# Direct-Telegram route only (/api/management/telegram). With Botpress in
# front, leave all three empty — Botpress owns the channel and the reply.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=

# Fed to the extraction prompt so «أحمد» maps onto the canonical spelling,
# and offered as autocomplete in the form.
MANAGEMENT_TEAM=
MANAGEMENT_DEPARTMENTS=

# Extraction model + the timezone every relative date is resolved against.
MANAGEMENT_MODEL=claude-opus-4-8
MANAGEMENT_TIMEZONE=Africa/Cairo
