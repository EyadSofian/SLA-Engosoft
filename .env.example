# ─────────────────────────────────────────────────────────────
# Supabase (client-side — MUST be the PUBLISHABLE / anon key)
# Never put the secret (service_role) key here: this value ships
# to the browser inside the built JS bundle.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://jrenyjmbbizborhbwptz.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Currency for every money figure. The database stores bare numbers with no
# currency column, so this is the single place that decides the unit.
# Defaults to USD — set these only to override.
# Supported: USD ($) · EUR (€) · GBP (£) · EGP (ج.م) · SAR (ر.س) · AED (د.إ) · KWD (د.ك)
# Keep both in step: VITE_CURRENCY drives the UI, CURRENCY the digest + AI chat.
VITE_CURRENCY=USD
CURRENCY=USD

# ─────────────────────────────────────────────────────────────
# AI chat proxy (server-side only — never prefixed with VITE_)
# Used by server/index.js and api/chat.ts
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# Port for the production server (Railway injects this automatically)
PORT=3000

# ─────────────────────────────────────────────────────────────
# Telegram daily digest (only for scripts/telegram-digest.js)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
SUPABASE_URL=https://jrenyjmbbizborhbwptz.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
